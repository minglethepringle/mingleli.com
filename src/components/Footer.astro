---
import { socials, site } from "../data/site";
import Icon from "./Icon.astro";
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-5 px-5 py-10 sm:flex-row sm:px-8"
  >
    <div class="flex items-center gap-3">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener"
            aria-label={s.label}
            class="grid size-9 place-items-center rounded-lg border border-border text-muted transition-colors hover:border-accent hover:text-accent"
          >
            <Icon name={s.name} class="size-[18px]" />
          </a>
        ))
      }
    </div>

    <p class="text-center text-sm text-muted sm:text-right">
      © {year}. Made with Astro, Tailwind, and Claude Code.
    </p>
  </div>
</footer>
