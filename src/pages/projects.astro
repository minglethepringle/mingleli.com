---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects"
  description="A selection of coding projects by Mingle Li, from hackathon wins to tools, bots, and games."
>
  <section class="mx-auto max-w-5xl px-5 py-16 sm:px-8">
    <PageHeader
      eyebrow="projects"
      title="Things I've built"
      subtitle="Back in my day, we had to code stuff by hand!"
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>
</BaseLayout>
