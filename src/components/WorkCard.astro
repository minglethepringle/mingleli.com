---
import type { Job } from "../data/work";
interface Props {
  job: Job;
}
const { job } = Astro.props;
---

<article
  class="rounded-xl border border-border bg-surface p-6 transition-colors hover:border-accent/40 sm:p-7"
>
  <div class="flex items-start gap-4 sm:gap-5">
    <img
      src={job.logo}
      alt={job.alt}
      loading="lazy"
      class="size-12 shrink-0 rounded-lg border border-border bg-white object-contain p-1.5 sm:size-14"
    />
    <div class="min-w-0 flex-1">
      <h3 class="font-display text-lg font-semibold tracking-tight">
        {job.company}
      </h3>

      {
        job.roles.map((role, i) => (
          <div class={i > 0 ? "mt-5 border-t border-border pt-5" : "mt-1"}>
            <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <h4 class="font-medium">{role.title}</h4>
              <span class="font-mono text-xs text-muted">{role.date}</span>
            </div>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-relaxed text-muted marker:text-accent">
              {role.bullets.map((b) => (
                <li set:html={b} />
              ))}
            </ul>
          </div>
        ))
      }

      <ul class="mt-5 flex flex-wrap gap-2">
        {
          job.tech.map((t) => (
            <li class="rounded-full border border-border bg-surface-2 px-2.5 py-1 font-mono text-xs text-muted">
              {t}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</article>
