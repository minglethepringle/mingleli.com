---
import { nav, site } from "../data/site";
import ThemeToggle from "./ThemeToggle.astro";

const current = (Astro.url.pathname.replace(/\/+$/, "") || "/").toLowerCase();
const isActive = (href: string) =>
  href === "/" ? current === "/" : current === href || current.startsWith(href + "/");
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-3 sm:px-8">
    <a
      href="/"
      class="group flex items-center gap-2.5 font-display text-lg font-bold tracking-tight"
    >
      <span class="grid size-7 place-items-center rounded-md bg-accent text-sm text-accent-fg">
        ML
      </span>
    </a>

    <div class="flex items-center gap-1.5">
      <ul class="hidden items-center gap-1 sm:flex">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class:list={[
                  "rounded-lg px-3 py-1.5 text-sm font-medium transition-colors",
                  isActive(item.href)
                    ? "bg-surface-2 text-fg"
                    : "text-muted hover:text-fg",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <ThemeToggle />

      <button
        id="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
        class="grid size-9 place-items-center rounded-lg border border-border text-muted transition-colors hover:bg-surface-2 hover:text-fg sm:hidden"
      >
        <svg
          viewBox="0 0 24 24"
          class="size-[18px]"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
    </div>
  </nav>

  <div id="nav-menu" class="hidden border-t border-border px-5 pb-3 sm:hidden">
    <ul class="flex flex-col gap-1 pt-2">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? "page" : undefined}
              class:list={[
                "block rounded-lg px-3 py-2 text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "bg-surface-2 text-fg"
                  : "text-muted hover:bg-surface-2 hover:text-fg",
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  (() => {
    const btn = document.getElementById("nav-toggle");
    const menu = document.getElementById("nav-menu");
    if (!btn || !menu) return;
    btn.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(open === false));
    });
  })();
</script>
