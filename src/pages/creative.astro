---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import TrackCard from "../components/TrackCard.astro";
import Gallery from "../components/Gallery.astro";
import { tracks } from "../data/creative";
---

<BaseLayout
  title="Creative"
  description="Music, photography, and other creative works by Mingle Li."
>
  <section class="mx-auto max-w-5xl px-5 py-16 sm:px-8">
    <PageHeader
      eyebrow="creative"
      title="Portfolio"
      subtitle="My attempts at producing professional content (as an amateur)."
    />

    <!-- Music -->
    <div>
      <h2 class="font-display text-2xl font-bold tracking-tight">Music</h2>
      <p class="mt-2 text-muted text-sm sm:text-base">I love listening to EDM, but making it is hard.</p>
      <div class="mt-8 space-y-5">
        {tracks.map((track) => <TrackCard track={track} />)}
      </div>
    </div>

    <!-- Photography -->
    <div class="mt-20">
      <h2 class="font-display text-2xl font-bold tracking-tight">Photography</h2>
      <p class="mt-2 text-muted text-sm sm:text-base">Shot on iPhone. Tap to enlarge.</p>
      <div class="mt-8">
        <Gallery />
      </div>
    </div>
  </section>
</BaseLayout>
