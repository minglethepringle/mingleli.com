---
import type { Track } from "../data/creative";
interface Props {
  track: Track;
}
const { track } = Astro.props;
const embed = `https://www.youtube.com/embed/${track.youtubeId}?rel=0&modestbranding=1`;
---

<article
  class="overflow-hidden rounded-xl border border-border bg-surface sm:flex"
>
  <!-- YouTube embed -->
  <div class="aspect-video shrink-0 bg-surface-2 sm:aspect-auto sm:w-64">
    <iframe
      src={embed}
      title={track.title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      referrerpolicy="strict-origin-when-cross-origin"
      class="h-full w-full"></iframe>
  </div>

  <!-- Content -->
  <div class="flex min-w-0 flex-1 flex-col justify-center gap-1 p-4 sm:p-5">
    <h3 class="font-display text-sm font-semibold leading-snug tracking-tight sm:text-base">
      {track.title}
    </h3>
    <p
      class="text-xs leading-relaxed text-muted sm:text-sm"
      set:html={track.description}
    />
  </div>
</article>
